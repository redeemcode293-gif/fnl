import { useState } from "react";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Badge } from "@/components/ui/badge";
import { Checkbox } from "@/components/ui/checkbox";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { Progress } from "@/components/ui/progress";
import { supabase } from "@/integrations/supabase/client";
import { useToast } from "@/hooks/use-toast";
import {
  RefreshCw, Search, Download, CheckSquare, Square,
  AlertCircle, ChevronDown, ChevronRight, Zap, Globe,
} from "lucide-react";

interface ProviderService {
  service: number | string;
  name: string;
  category: string;
  rate: string | number;
  min: string | number;
  max: string | number;
  refill?: boolean | string;
  dripfeed?: boolean | string;
  description?: string;
}

const PLATFORMS = ["Instagram","YouTube","TikTok","Telegram","X","Facebook","Spotify","Discord","Twitch","Snapchat","WhatsApp","Threads","LinkedIn","Pinterest","Reddit","Apple","Other"];
const INR_TO_USD = 1 / 83.5; // 1 INR ≈ 0.01198 USD (1 USD = 83.5 INR as of 2024-25)
// To update: change the denominator to current USD/INR exchange rate

/**
 * Robust price parser.
 * - Strips commas (₹1,00,000 → 100000 or $1,000 → 1000)
 * - Strips currency symbols
 * - Returns the raw numeric value (caller decides USD vs INR conversion)
 */
function parseRawPrice(raw: string | number): number {
  if (typeof raw === "number") return isNaN(raw) ? 0 : raw;
  if (!raw) return 0;
  const cleaned = String(raw).replace(/[₹Rs$€£\s,]/g, "").trim();
  const parsed = parseFloat(cleaned);
  return isNaN(parsed) ? 0 : parsed;
}

/**
 * Convert provider price to USD for storage.
 * If provider currency is INR (or price looks like INR — i.e. > 100 for a typical SMM service),
 * divide by INR_TO_USD rate.
 */
function toUsdPrice(raw: string | number, providerCurrency: string): number {
  const value = parseRawPrice(raw);
  if (value === 0) return 0;
  const cur = (providerCurrency || "USD").toUpperCase();
  if (cur === "INR" || cur === "RS" || cur === "₹") {
    return value * INR_TO_USD;
  }
  // Heuristic: if not explicitly INR but value > 50 (no real SMM service costs $50+ per 1K in USD),
  // it's almost certainly stored as INR. Typical SMM prices in USD are < $20/1K.
  if (cur === "USD" && value > 50) {
    console.warn(`Price ${value} looks like INR (too high for USD/1K), auto-converting`);
    return value * INR_TO_USD;
  }
  return value;
}

function detectPlatform(category: string, name: string): string {
  const text = (category + " " + name).toLowerCase();
  if (text.includes("instagram")) return "Instagram";
  if (text.includes("youtube") || text.includes("yt ")) return "YouTube";
  if (text.includes("tiktok") || text.includes("tik tok")) return "TikTok";
  if (text.includes("telegram")) return "Telegram";
  if (text.includes("twitter") || text.includes(" x ") || text.includes("tweet")) return "X";
  if (text.includes("facebook") || text.includes("fb ")) return "Facebook";
  if (text.includes("spotify")) return "Spotify";
  if (text.includes("discord")) return "Discord";
  if (text.includes("twitch")) return "Twitch";
  if (text.includes("snapchat")) return "Snapchat";
  if (text.includes("whatsapp")) return "WhatsApp";
  if (text.includes("threads")) return "Threads";
  if (text.includes("linkedin")) return "LinkedIn";
  if (text.includes("pinterest")) return "Pinterest";
  if (text.includes("reddit")) return "Reddit";
  if (text.includes("apple") || text.includes("itunes")) return "Apple";
  return "Other";
}

export const BulkServiceImport = () => {
  const { toast } = useToast();
  const [apiUrl, setApiUrl] = useState("");
  const [apiKey, setApiKey] = useState("");
  const [providerName, setProviderName] = useState("");
  const [providerCurrency, setProviderCurrency] = useState("USD");
  const [services, setServices] = useState<ProviderService[]>([]);
  const [selected, setSelected] = useState<Set<string | number>>(new Set());
  const [loading, setLoading] = useState(false);
  const [importing, setImporting] = useState(false);
  const [importProgress, setImportProgress] = useState(0);
  const [importTotal, setImportTotal] = useState(0);
  const [searchQuery, setSearchQuery] = useState("");
  const [platformFilter, setPlatformFilter] = useState("all");
  const [marginPercent, setMarginPercent] = useState("30");
  const [expandedCategories, setExpandedCategories] = useState<Set<string>>(new Set());

  // Direct API fetch — tries direct call first, then falls back to edge function
  const fetchServices = async () => {
    if (!apiUrl || !apiKey) {
      toast({ title: "Please enter API URL and Key", variant: "destructive" });
      return;
    }
    setLoading(true);
    setServices([]);
    setSelected(new Set());

    try {
      // Try fetching provider services directly (standard SMM panel API)
      const targetUrl = apiUrl.trim().replace(/\/$/, "");
      const formData = new FormData();
      formData.append("key", apiKey.trim());
      formData.append("action", "services");

      // Use Supabase edge function to proxy the request (avoids CORS)
      const { data, error } = await supabase.functions.invoke("sync-provider", {
        body: {
          action: "fetch-preview",
          apiUrl: targetUrl,
          apiKey: apiKey.trim(),
        },
      });

      if (error) throw new Error(error.message || "Edge function error");
      if (!Array.isArray(data?.services)) {
        throw new Error(data?.error || "Invalid response — expected array of services");
      }

      const fetched: ProviderService[] = data.services;
      setServices(fetched);

      // Auto-detect currency from first service
      if (fetched.length > 0) {
        const samplePrice = parseRawPrice(fetched[0].rate);
        if (samplePrice > 80) {
          setProviderCurrency("INR");
          toast({
            title: `Fetched ${fetched.length} services`,
            description: "Detected INR pricing — prices will be converted to USD automatically.",
          });
        } else {
          toast({ title: `Fetched ${fetched.length} services from provider` });
        }
      }
    } catch (err: any) {
      toast({ title: "Failed to fetch services", description: err.message, variant: "destructive" });
    }
    setLoading(false);
  };

  const filteredServices = services.filter((s) => {
    const platform = detectPlatform(s.category, s.name);
    const matchesPlatform = platformFilter === "all" || platform === platformFilter;
    const q = searchQuery.toLowerCase().trim();
    const matchesSearch = !q ||
      s.name.toLowerCase().includes(q) ||
      s.category.toLowerCase().includes(q) ||
      String(s.service).includes(q);
    return matchesPlatform && matchesSearch;
  });

  // Group by provider category (preserves provider grouping)
  const groupedByCategory = filteredServices.reduce((acc, s) => {
    const cat = s.category || "Uncategorized";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(s);
    return acc;
  }, {} as Record<string, ProviderService[]>);

  const toggleSelectAll = () => {
    if (selected.size === filteredServices.length) {
      setSelected(new Set());
    } else {
      setSelected(new Set(filteredServices.map((s) => s.service)));
    }
  };

  const toggleService = (id: string | number) => {
    const next = new Set(selected);
    next.has(id) ? next.delete(id) : next.add(id);
    setSelected(next);
  };

  const toggleCategory = (cat: string, e: React.MouseEvent) => {
    e.stopPropagation();
    const catServices = groupedByCategory[cat] || [];
    const allSelected = catServices.every((s) => selected.has(s.service));
    const next = new Set(selected);
    allSelected
      ? catServices.forEach((s) => next.delete(s.service))
      : catServices.forEach((s) => next.add(s.service));
    setSelected(next);
  };

  const toggleExpand = (cat: string) => {
    const next = new Set(expandedCategories);
    next.has(cat) ? next.delete(cat) : next.add(cat);
    setExpandedCategories(next);
  };

  const importSelected = async () => {
    if (selected.size === 0) {
      toast({ title: "No services selected", variant: "destructive" });
      return;
    }
    setImporting(true);
    setImportProgress(0);
    const toImport = services.filter((s) => selected.has(s.service));
    setImportTotal(toImport.length);

    const margin = parseFloat(marginPercent) / 100 || 0.3;

    try {
      // 1. Upsert provider record
      let providerId: string | null = null;
      {
        const { data: existing } = await supabase
          .from("api_providers")
          .select("id")
          .eq("api_url", apiUrl.trim())
          .maybeSingle();

        if (existing) {
          providerId = existing.id;
          await supabase.from("api_providers").update({
            api_key: apiKey.trim(),
            currency: providerCurrency,
            status: "active",
          }).eq("id", providerId);
        } else {
          const { data: created, error: ce } = await supabase
            .from("api_providers")
            .insert({
              name: providerName.trim() || new URL(apiUrl).hostname,
              api_url: apiUrl.trim(),
              api_key: apiKey.trim(),
              currency: providerCurrency,
              status: "active",
            })
            .select("id")
            .single();
          if (ce) throw new Error("Failed to save provider: " + ce.message);
          providerId = created.id;
        }
      }

      // 2. Import in batches of 50 (fast + avoids timeout)
      const BATCH = 50;
      let added = 0, updated = 0;

      for (let i = 0; i < toImport.length; i += BATCH) {
        const batch = toImport.slice(i, i + BATCH);
        const batchIds = batch.map((s) => String(s.service));

        // Check existing
        const { data: existing } = providerId
          ? await supabase
              .from("services")
              .select("id, provider_service_id")
              .eq("provider_id", providerId)
              .in("provider_service_id", batchIds)
          : { data: [] };

        const existingMap = new Map((existing || []).map((s: any) => [s.provider_service_id, s.id]));

        const toInsert: any[] = [];
        const toUpdate: any[] = [];

        for (const svc of batch) {
          const platform = detectPlatform(svc.category, svc.name);
          const rawPrice = parseRawPrice(svc.rate);
          // Convert INR → USD if needed
          const providerPriceUsd = providerCurrency === "INR" || rawPrice > 50
            ? rawPrice * INR_TO_USD
            : rawPrice;
          const panelPrice = providerPriceUsd * (1 + margin);
          const pid = String(svc.service);

          const row = {
            name: svc.name,
            description: svc.description || svc.name,
            platform,
            category: svc.category || "General",
            provider_id: providerId,
            provider_service_id: pid,
            provider_price: providerPriceUsd,
            base_price: panelPrice,
            min_quantity: parseInt(String(svc.min)) || 100,
            max_quantity: parseInt(String(svc.max)) || 50000,
            refill_supported: svc.refill === true || svc.refill === "true",
            dripfeed_supported: svc.dripfeed === true || svc.dripfeed === "true",
            is_active: true, // Auto-live on import
          };

          if (existingMap.has(pid)) {
            toUpdate.push({ id: existingMap.get(pid), ...row });
          } else {
            // Unique service_id: use provider ID + offset to avoid collisions
            toInsert.push({ ...row, service_id: parseInt(pid) || Math.floor(10000 + Math.random() * 89999) });
          }
        }

        // Batch insert new services
        if (toInsert.length > 0) {
          const { error: ie } = await supabase.from("services").insert(toInsert);
          if (!ie) {
            added += toInsert.length;
            // Also push to panel_services (user-facing) — auto-visible
            const panelRows = toInsert.map((s) => ({
              service_id: s.service_id,
              name: s.name,
              description: s.description,
              platform: s.platform,
              category: s.category,
              price: s.base_price,
              min_quantity: s.min_quantity,
              max_quantity: s.max_quantity,
              refill_supported: s.refill_supported,
              dripfeed_supported: s.dripfeed_supported,
              auto_refill_supported: false,
              is_visible: true, // Visible to users immediately
              provider_service_uuid: null,
            }));
            await supabase.from("panel_services").upsert(panelRows, { onConflict: "service_id" });
          } else {
            // Fallback: insert one by one (handles duplicate service_id conflicts)
            for (const s of toInsert) {
              const { data: ins } = await supabase.from("services").insert({ ...s, service_id: Math.floor(10000 + Math.random() * 89999) }).select("id").single();
              if (ins) {
                added++;
                await supabase.from("panel_services").insert({
                  service_id: s.service_id,
                  name: s.name, description: s.description, platform: s.platform,
                  category: s.category, price: s.base_price,
                  min_quantity: s.min_quantity, max_quantity: s.max_quantity,
                  refill_supported: s.refill_supported, dripfeed_supported: s.dripfeed_supported,
                  auto_refill_supported: false, is_visible: true,
                });
              }
            }
          }
        }

        // Update existing services
        for (const s of toUpdate) {
          const { id, ...data } = s;
          await supabase.from("services").update(data).eq("id", id);
          // Update panel_services price too
          await supabase.from("panel_services").update({ price: data.base_price, is_visible: true }).eq("service_id", data.service_id);
          updated++;
        }

        setImportProgress(Math.min(i + BATCH, toImport.length));
      }

      // Update provider sync time
      if (providerId) {
        await supabase.from("api_providers").update({ last_sync_at: new Date().toISOString() }).eq("id", providerId);
      }

      toast({
        title: "Import Complete ✓",
        description: `Added: ${added} new services, Updated: ${updated}. All are live for users immediately.`,
      });
      setSelected(new Set());
    } catch (err: any) {
      toast({ title: "Import Failed", description: err.message, variant: "destructive" });
    }
    setImporting(false);
    setImportProgress(0);
  };

  const allFilteredSelected = filteredServices.length > 0 && filteredServices.every((s) => selected.has(s.service));
  const progressPct = importTotal > 0 ? Math.round((importProgress / importTotal) * 100) : 0;

  return (
    <div className="space-y-6">
      {/* Connection */}
      <Card className="border-border/30 bg-card/60">
        <CardHeader>
          <CardTitle className="text-lg font-display flex items-center gap-2">
            <Zap className="h-5 w-5 text-primary" />
            Bulk Service Import
          </CardTitle>
          <CardDescription>
            Enter provider API credentials → Fetch → Select → Import. All imported services go live instantly.
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div className="space-y-2">
              <Label>Provider Name</Label>
              <Input placeholder="e.g., SMM Panel Pro" value={providerName} onChange={(e) => setProviderName(e.target.value)} className="bg-secondary/30 border-border/30" />
            </div>
            <div className="space-y-2">
              <Label>API URL</Label>
              <Input placeholder="https://provider.com/api/v2" value={apiUrl} onChange={(e) => setApiUrl(e.target.value)} className="bg-secondary/30 border-border/30" />
            </div>
            <div className="space-y-2">
              <Label>API Key</Label>
              <Input type="password" placeholder="Your API key" value={apiKey} onChange={(e) => setApiKey(e.target.value)} className="bg-secondary/30 border-border/30" />
            </div>
            <div className="space-y-2">
              <Label>Provider Currency</Label>
              <Select value={providerCurrency} onValueChange={setProviderCurrency}>
                <SelectTrigger className="bg-secondary/30 border-border/30">
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="USD">USD ($)</SelectItem>
                  <SelectItem value="INR">INR (₹) — auto-converts to USD</SelectItem>
                  <SelectItem value="EUR">EUR (€)</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </div>
          {providerCurrency === "INR" && (
            <div className="p-3 rounded-lg bg-amber-500/10 border border-amber-500/30 text-sm text-amber-700 dark:text-amber-400">
              INR mode: provider prices will be automatically divided by ~83 to convert to USD before saving. Your panel will show correct USD prices.
            </div>
          )}
          <Button onClick={fetchServices} disabled={loading} className="w-full md:w-auto">
            {loading ? <><RefreshCw className="h-4 w-4 mr-2 animate-spin" />Fetching…</> : <><RefreshCw className="h-4 w-4 mr-2" />Fetch Provider Services</>}
          </Button>
        </CardContent>
      </Card>

      {/* Selection */}
      {services.length > 0 && (
        <Card className="border-border/30 bg-card/60">
          <CardHeader>
            <div className="flex flex-wrap items-center justify-between gap-4">
              <div>
                <CardTitle className="text-lg font-display">
                  Select Services to Import
                  <Badge variant="outline" className="ml-2 font-mono">{services.length} total</Badge>
                </CardTitle>
                <CardDescription>
                  {selected.size} selected · Groups preserved from provider · Auto-live on import
                </CardDescription>
              </div>
              <div className="flex items-center gap-2 flex-wrap">
                <div className="space-y-1">
                  <Label className="text-xs">Margin %</Label>
                  <Input type="number" min="0" max="500" value={marginPercent} onChange={(e) => setMarginPercent(e.target.value)} className="w-20 h-8 bg-secondary/30 border-border/30 text-sm" />
                </div>
                <Button onClick={importSelected} disabled={importing || selected.size === 0} className="self-end">
                  {importing
                    ? <><RefreshCw className="h-4 w-4 mr-2 animate-spin" />{importProgress}/{importTotal}</>
                    : <><Download className="h-4 w-4 mr-2" />Import {selected.size} Services</>}
                </Button>
              </div>
            </div>
            {importing && (
              <div className="space-y-1 pt-2">
                <Progress value={progressPct} className="h-2" />
                <p className="text-xs text-muted-foreground text-center">{progressPct}% — {importProgress} of {importTotal} services processed</p>
              </div>
            )}
            <div className="flex flex-wrap gap-3 pt-2">
              <div className="relative flex-1 min-w-[180px]">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                <Input placeholder="Search services…" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} className="pl-9 bg-secondary/30 border-border/30" />
              </div>
              <Select value={platformFilter} onValueChange={setPlatformFilter}>
                <SelectTrigger className="w-40 bg-secondary/30 border-border/30">
                  <Globe className="h-4 w-4 mr-2" /><SelectValue placeholder="Platform" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="all">All Platforms</SelectItem>
                  {PLATFORMS.map((p) => <SelectItem key={p} value={p}>{p}</SelectItem>)}
                </SelectContent>
              </Select>
              <Button variant="outline" size="sm" onClick={toggleSelectAll} className="gap-2 self-center">
                {allFilteredSelected ? <><CheckSquare className="h-4 w-4" />Deselect All</> : <><Square className="h-4 w-4" />Select All</>}
              </Button>
            </div>
          </CardHeader>

          <CardContent>
            {filteredServices.length === 0 ? (
              <div className="text-center py-8">
                <AlertCircle className="h-8 w-8 mx-auto text-muted-foreground/50 mb-2" />
                <p className="text-muted-foreground text-sm">No services match filters</p>
              </div>
            ) : (
              <div className="space-y-2">
                {Object.entries(groupedByCategory).sort(([a],[b]) => a.localeCompare(b)).map(([category, catSvcs]) => {
                  const catSelected = catSvcs.filter((s) => selected.has(s.service)).length;
                  const allCat = catSelected === catSvcs.length;
                  const isExp = expandedCategories.has(category);

                  return (
                    <div key={category} className="border border-border/20 rounded-lg overflow-hidden">
                      <div className="flex items-center gap-3 p-3 bg-secondary/20 cursor-pointer hover:bg-secondary/30 transition-colors" onClick={() => toggleExpand(category)}>
                        {isExp ? <ChevronDown className="h-4 w-4 text-muted-foreground shrink-0" /> : <ChevronRight className="h-4 w-4 text-muted-foreground shrink-0" />}
                        <div onClick={(e) => toggleCategory(category, e)}>
                          <Checkbox checked={allCat} onCheckedChange={() => {}} />
                        </div>
                        <span className="font-medium text-sm flex-1">{category}</span>
                        <Badge variant="outline" className="text-xs font-mono">{catSelected}/{catSvcs.length}</Badge>
                      </div>
                      {isExp && (
                        <div className="divide-y divide-border/10">
                          {catSvcs.map((svc) => {
                            const platform = detectPlatform(svc.category, svc.name);
                            const rawPrice = parseRawPrice(svc.rate);
                            const providerUsd = providerCurrency === "INR" || rawPrice > 80 ? rawPrice * INR_TO_USD : rawPrice;
                            const panelUsd = providerUsd * (1 + parseFloat(marginPercent) / 100);

                            return (
                              <div
                                key={svc.service}
                                className={`flex items-center gap-3 p-3 hover:bg-secondary/10 cursor-pointer ${selected.has(svc.service) ? "bg-primary/5" : ""}`}
                                onClick={() => toggleService(svc.service)}
                              >
                                <Checkbox checked={selected.has(svc.service)} onCheckedChange={() => toggleService(svc.service)} onClick={(e) => e.stopPropagation()} />
                                <div className="flex-1 min-w-0">
                                  <p className="text-sm font-medium truncate">{svc.name}</p>
                                  <div className="flex items-center gap-2 mt-0.5 flex-wrap">
                                    <span className="text-xs text-muted-foreground font-mono">ID:{svc.service}</span>
                                    <Badge variant="secondary" className="text-xs h-4 px-1">{platform}</Badge>
                                    {svc.refill && <Badge variant="outline" className="text-xs h-4 px-1 text-success border-success/30">Refill</Badge>}
                                  </div>
                                </div>
                                <div className="text-right shrink-0 space-y-0.5">
                                  <p className="text-xs text-muted-foreground">
                                    Provider: {providerCurrency === "INR" ? `₹${rawPrice.toFixed(2)}` : rawPrice > 50 ? `₹${rawPrice.toFixed(2)} (auto-INR)` : `$${providerUsd.toFixed(4)}`}/1K
                                  </p>
                                  <p className="text-xs font-medium text-primary">${panelUsd.toFixed(4)}/1K</p>
                                </div>
                                <div className="text-right shrink-0 text-xs text-muted-foreground">
                                  {parseInt(String(svc.min)).toLocaleString()}–{parseInt(String(svc.max)).toLocaleString()}
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            )}
          </CardContent>
        </Card>
      )}
    </div>
  );
};
